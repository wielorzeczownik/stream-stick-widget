{
  "version": "0.2.10",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build && tixyel b -b none",
    "compile": "vite build",
    "test:watch": "vitest",
    "lint": "eslint widget/src/scripts widget/src/index.html",
    "lint:scss": "stylelint \"widget/src/styles/**/*.scss\"",
    "format": "prettier --write widget/src/scripts widget/src/index.html",
    "format:check": "prettier --check widget/src/scripts widget/src/index.html",
    "typecheck": "tsc --noEmit",
    "fix": "eslint --fix widget/src/scripts widget/src/index.html && stylelint --fix \"widget/src/styles/**/*.scss\" && prettier --write widget/src/scripts widget/src/index.html"
  },
  "devDependencies": {
    "@html-eslint/eslint-plugin": "0.63.0",
    "@html-eslint/parser": "0.63.0",
    "@tixyel/cli": "3.6.0",
    "@types/node": "26.1.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-unicorn": "71.1.0",
    "jiti": "2.7.0",
    "prettier": "3.9.4",
    "rollup-plugin-external-globals": "0.13.0",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vite-plugin-static-copy": "4.1.1"
  },
  "dependencies": {
    "@tixyel/streamelements": "7.14.1",
    "@types/three": "0.185.1",
    "motion": "12.42.2",
    "three": "0.185.1"
  }
}
